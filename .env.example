# LLM provider
# Final validated provider: ollama
# Alternative supported provider: mistral
LLM_PROVIDER=ollama
LLM_FALLBACK_ORDER=ollama,mock
LLM_FALLBACK_TO_MOCK=true
LLM_DEBUG=false

# Ollama local configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=300

# Mistral optional external provider
# Use only when running with LLM_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_SECONDS=120

# Optional reproducibility cache
LLM_CACHE_PATH=../data/processed/llm_cache_final_ollama.json

# Dataset
DATA_SOURCE=mimic_iv_ed
MIMIC_IV_ED_TRIAGE_CSV=../data/raw/mimic-iv-ed-demo/ed/triage.csv

# Safety note:
# Do not commit .env files, datasets, processed data, LLM caches, or full experiment outputs.
