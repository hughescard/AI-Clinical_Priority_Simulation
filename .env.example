# For deterministic mock-only experiments, use:
# LLM_PROVIDER=mock

# Recommended default for final experiments:
LLM_PROVIDER=ollama
LLM_FALLBACK_ORDER=ollama,mock
LLM_DEBUG=false

# Mock mode does not require API keys.

# Set these only for the providers you actually use. Do not commit real credentials.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
LLM_FALLBACK_TO_MOCK=true

# Ollama runs as a separate Docker service and is reached over the internal Docker network in Docker.
# When running locally outside Docker, use:
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30

# Cache file inside the Docker container for final validations.
LLM_CACHE_PATH=/app/data/processed/llm_cache_final_ollama.json

# Dataset files should be placed under ./data/raw on the host.
# Inside Docker they are mounted under /app/data/raw.
MIMIC_IV_ED_TRIAGE_CSV=/app/data/raw/mimic-iv-ed-demo/ed/triage.csv
MIETIC_CSV=

# Do not commit real credentials.
# Do not commit real clinical data into this repository.
# Ollama is the recommended default for final experiments because it does not require quota.
